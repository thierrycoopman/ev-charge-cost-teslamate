# Tesla Sync — Environment Variables
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains passwords.
# ════════════════════════════════════════════════════════════════════════════


# ── Tesla Account ─────────────────────────────────────────────────────────────
# Your Tesla account email (used only for reference; login is via browser OAuth)
TESLA_EMAIL=your@email.com

# Your country code and locale (affects currency and language in API responses)
# Use ISO 3166-1 alpha-2 for TESLA_COUNTRY (e.g. FR, CH, US, DE, GB, BE)
TESLA_COUNTRY=BE
TESLA_LOCALE=fr_BE

# Token file location.
# • On host (dev):     leave blank — defaults to ~/.tesla_tokens.json
# • In Docker:        set automatically to /app/data/tesla_tokens.json
#                     (don't change this unless you know what you're doing)
# TESLA_TOKEN_FILE=/app/data/tesla_tokens.json


# ── TeslaMate Database ────────────────────────────────────────────────────────
# Used by sync_teslamate_costs.py and sync_evc_costs.py to write costs.
#
# ┌─ Running scripts on the HOST (outside Docker): ─────────────────────────┐
# │  You need port 5432 exposed in TeslaMate's docker-compose.yml:          │
# │    database:                                                             │
# │      ports:                                                              │
# │        - "5432:5432"                                                     │
# │  Then use localhost:                                                     │
# │    TESLAMATE_DATABASE_URL=postgresql://teslamate:teslamate@localhost:5432/teslamate
# └─────────────────────────────────────────────────────────────────────────┘
#
# ┌─ Running inside Docker (docker-compose.yml in this repo): ───────────────┐
# │  The container joins TeslaMate's internal network, so use the service    │
# │  name "database" instead of "localhost" — no port exposure needed.       │
# │    TESLAMATE_DATABASE_URL=postgresql://teslamate:teslamate@database:5432/teslamate
# └─────────────────────────────────────────────────────────────────────────┘
TESLAMATE_DATABASE_URL=postgresql://teslamate:teslamate@database:5432/teslamate


# ── Docker Network ────────────────────────────────────────────────────────────
# The name of TeslaMate's Docker network. The tesla-sync container joins this
# network to reach the PostgreSQL container without exposing any ports.
#
# Find yours with:  docker network ls | grep tesla
# Common values:
#   teslamate_default   ← if TeslaMate folder is named "teslamate"
#   teslamate_teslamate ← some Portainer / custom setups
TESLAMATE_NETWORK=teslamate_default


# ── EVC-Net (Last Mile Solutions) ────────────────────────────────────────────
# Used by: python scripts/sync_evc_costs.py
#
# EVC-Net is a white-label platform — every charge network operator runs their
# own portal. Credentials are per-portal.
#
# ┌─ Single network (simple) ────────────────────────────────────────────────┐
# │  Set EVC_BASE_URL to your portal's URL.                                  │
# │  Run: python scripts/sync_evc_costs.py --list-networks                   │
# │  to see all known EVC-Net portals.                                       │
# └──────────────────────────────────────────────────────────────────────────┘
EVC_EMAIL=your@email.com
EVC_PASSWORD=yourpassword
EVC_BASE_URL=https://agrisnellaad.evc-net.com

# Timezone of your EVC portal's timestamps. EVC exports use local time, not UTC.
# TeslaMate stores UTC, so this offset is critical for correct session matching.
# Examples: Europe/Brussels, Europe/Amsterdam, Europe/Paris, Europe/London, UTC
EVC_TIMEZONE=Europe/Brussels

# ┌─ Multiple networks (accounts file) ──────────────────────────────────────┐
# │  If you have accounts on more than one EVC-Net portal, use the accounts  │
# │  file instead of the env vars above:                                     │
# │    cp evc_accounts.example.json evc_accounts.json                        │
# │    # fill in your credentials for each network                           │
# │  Then point to the file here (comment out EVC_EMAIL/PASSWORD above):     │
# └──────────────────────────────────────────────────────────────────────────┘
# EVC_ACCOUNTS_FILE=/app/evc_accounts.json


# ── Fleet API (Official — Optional) ──────────────────────────────────────────
# Only needed if you have a registered Tesla developer application.
# Most users do NOT need this — the private API works without it.
# TESLA_CLIENT_ID=your-fleet-api-client-id
# TESLA_CLIENT_SECRET=your-fleet-api-client-secret
